{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://diffgotchi.dev/schemas/config.json",
  "title": "Diffgotchi Configuration",
  "description": "Configuration file for Diffgotchi TUI diff reviewer (~/.config/diffgotchi/config.json)",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "general": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "theme": {
          "type": "string",
          "description": "Theme name to use.",
          "default": "github"
        },
        "editor": {
          "type": "string",
          "description": "Editor command to use when opening files. Falls back to $VISUAL, then $EDITOR, then vi.",
          "default": ""
        },
        "mouse": {
          "type": "boolean",
          "description": "Enable mouse support for scrolling and clicking.",
          "default": true
        }
      },
      "default": {
        "theme": "github",
        "editor": "",
        "mouse": true
      }
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "view": {
          "type": "string",
          "enum": ["auto", "split", "unified"],
          "description": "Diff layout mode.",
          "default": "auto"
        },
        "line_numbers": {
          "type": "boolean",
          "description": "Show line numbers.",
          "default": true
        },
        "wrap": {
          "type": "string",
          "enum": ["word", "char", "none"],
          "description": "How to wrap long lines.",
          "default": "word"
        },
        "inline_highlights": {
          "type": "boolean",
          "description": "Highlight changed content within added and removed lines.",
          "default": true
        },
        "backgrounds": {
          "type": "boolean",
          "description": "Show added and removed line backgrounds.",
          "default": true
        },
        "indicators": {
          "type": "string",
          "enum": ["classic", "none"],
          "description": "Line indicator style.",
          "default": "classic"
        },
        "hunk_headers": {
          "type": "boolean",
          "description": "Show diff hunk headers.",
          "default": true
        }
      },
      "default": {
        "view": "auto",
        "line_numbers": true,
        "wrap": "word",
        "inline_highlights": true,
        "backgrounds": true,
        "indicators": "classic",
        "hunk_headers": true
      }
    },
    "diff": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "context_lines": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of context lines around changes.",
          "default": 6
        },
        "refresh_debounce_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Debounce interval in milliseconds for refreshing watched diffs.",
          "default": 200
        },
        "max_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum total bytes of git diff output before truncation. Set to 0 to disable.",
          "default": 20971520
        },
        "max_file_lines": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum diff lines per file before showing a placeholder. Set to 0 to disable.",
          "default": 5000
        },
        "filetypes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Custom extension/filename to tree-sitter language mappings. Keys are extensions or filenames.",
          "default": {}
        },
        "ignored_files": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "JavaScript regex pattern (e.g. \"\\\\.lock$\")."
          },
          "description": "Regex patterns for files to ignore in diff view.",
          "default": ["\\.lock$", "lock\\.json$", "lock\\.yaml$", "lock\\.toml$", "\\.sum$"]
        }
      },
      "default": {
        "context_lines": 6,
        "refresh_debounce_ms": 200,
        "max_bytes": 20971520,
        "max_file_lines": 5000,
        "filetypes": {},
        "ignored_files": ["\\.lock$", "lock\\.json$", "lock\\.yaml$", "lock\\.toml$", "\\.sum$"]
      }
    },
    "upgrade": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "auto": {
          "type": "boolean",
          "description": "Automatically check for and install upgrades on startup.",
          "default": true
        },
        "channel": {
          "type": "string",
          "enum": ["stable", "canary"],
          "description": "Which release channel to check for upgrades.",
          "default": "stable"
        }
      },
      "default": {
        "auto": true,
        "channel": "stable"
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cleanup_stale_days": {
          "type": "integer",
          "minimum": 0,
          "description": "Delete stale review/session state older than this many days. Set to 0 to disable cleanup.",
          "default": 30
        }
      },
      "default": {
        "cleanup_stale_days": 30
      }
    },
    "keybinds": {
      "type": "object",
      "description": "Keyboard shortcuts. Empty string means the action is intentionally unbound.",
      "propertyNames": {
        "pattern": "^[^.]+\\.[^.]+$"
      },
      "additionalProperties": {
        "type": "string"
      },
      "properties": {
        "global.command_palette": {
          "type": "string",
          "default": "ctrl+p"
        },
        "global.quit": {
          "type": "string",
          "default": "ctrl+c, ctrl+d"
        },
        "global.help_keybinds": {
          "type": "string",
          "default": ""
        },
        "global.help_about": {
          "type": "string",
          "default": ""
        },
        "global.help_docs": {
          "type": "string",
          "default": ""
        },
        "global.open_config": {
          "type": "string",
          "default": ""
        },
        "diff.next_file": {
          "type": "string",
          "default": "right, l"
        },
        "diff.prev_file": {
          "type": "string",
          "default": "left, h"
        },
        "diff.pick_file": {
          "type": "string",
          "default": "/, ctrl+k f"
        },
        "diff.edit_file": {
          "type": "string",
          "default": "ctrl+g, ctrl+k e"
        },
        "diff.scroll_down": {
          "type": "string",
          "default": "down, j"
        },
        "diff.scroll_up": {
          "type": "string",
          "default": "up, k"
        },
        "diff.scroll_half_down": {
          "type": "string",
          "default": "ctrl+down, pagedown"
        },
        "diff.scroll_half_up": {
          "type": "string",
          "default": "ctrl+up, pageup"
        },
        "diff.scroll_top": {
          "type": "string",
          "default": "home"
        },
        "diff.scroll_bottom": {
          "type": "string",
          "default": "ctrl+alt+g, end"
        },
        "diff.next_hunk": {
          "type": "string",
          "default": "shift+down, shift+j, ]"
        },
        "diff.prev_hunk": {
          "type": "string",
          "default": "shift+up, shift+k, ["
        },
        "diff.mark_done": {
          "type": "string",
          "default": "d"
        },
        "diff.add_comment": {
          "type": "string",
          "default": "c"
        },
        "diff.list_comments": {
          "type": "string",
          "default": "ctrl+k r"
        },
        "diff.pick_theme": {
          "type": "string",
          "default": ""
        },
        "diff.force_expand": {
          "type": "string",
          "default": ""
        },
        "diff.display_view": {
          "type": "string",
          "default": ""
        },
        "diff.display_line_numbers": {
          "type": "string",
          "default": ""
        },
        "diff.display_wrap": {
          "type": "string",
          "default": ""
        },
        "diff.display_inline_highlights": {
          "type": "string",
          "default": ""
        },
        "diff.display_backgrounds": {
          "type": "string",
          "default": ""
        },
        "diff.display_indicators": {
          "type": "string",
          "default": ""
        },
        "diff.display_hunk_headers": {
          "type": "string",
          "default": ""
        },
        "diff.context_lines": {
          "type": "string",
          "default": ""
        },
        "diff.toggle_mouse": {
          "type": "string",
          "default": ""
        },
        "select.next": {
          "type": "string",
          "default": "down, j"
        },
        "select.prev": {
          "type": "string",
          "default": "up, k"
        },
        "select.accept": {
          "type": "string",
          "default": "return"
        },
        "select.cancel": {
          "type": "string",
          "default": "escape"
        },
        "file_picker.toggle_done": {
          "type": "string",
          "default": "ctrl+d"
        },
        "comments_list.resolve": {
          "type": "string",
          "default": "ctrl+r"
        },
        "comments_list.delete": {
          "type": "string",
          "default": "ctrl+x"
        },
        "comment_editor.submit": {
          "type": "string",
          "default": "ctrl+return, ctrl+enter, ctrl+j"
        },
        "comment_editor.delete": {
          "type": "string",
          "default": "ctrl+x"
        },
        "comment_editor.cancel": {
          "type": "string",
          "default": "escape"
        },
        "error.retry": {
          "type": "string",
          "default": "r"
        },
        "error.copy": {
          "type": "string",
          "default": "c"
        },
        "error.quit": {
          "type": "string",
          "default": "ctrl+c, ctrl+d"
        }
      },
      "default": {
        "global.command_palette": "ctrl+p",
        "global.quit": "ctrl+c, ctrl+d",
        "global.help_keybinds": "",
        "global.help_about": "",
        "global.help_docs": "",
        "global.open_config": "",
        "diff.next_file": "right, l",
        "diff.prev_file": "left, h",
        "diff.pick_file": "/, ctrl+k f",
        "diff.edit_file": "ctrl+g, ctrl+k e",
        "diff.scroll_down": "down, j",
        "diff.scroll_up": "up, k",
        "diff.scroll_half_down": "ctrl+down, pagedown",
        "diff.scroll_half_up": "ctrl+up, pageup",
        "diff.scroll_top": "home",
        "diff.scroll_bottom": "ctrl+alt+g, end",
        "diff.next_hunk": "shift+down, shift+j, ]",
        "diff.prev_hunk": "shift+up, shift+k, [",
        "diff.mark_done": "d",
        "diff.add_comment": "c",
        "diff.list_comments": "ctrl+k r",
        "diff.pick_theme": "",
        "diff.force_expand": "",
        "diff.display_view": "",
        "diff.display_line_numbers": "",
        "diff.display_wrap": "",
        "diff.display_inline_highlights": "",
        "diff.display_backgrounds": "",
        "diff.display_indicators": "",
        "diff.display_hunk_headers": "",
        "diff.context_lines": "",
        "diff.toggle_mouse": "",
        "select.next": "down, j",
        "select.prev": "up, k",
        "select.accept": "return",
        "select.cancel": "escape",
        "file_picker.toggle_done": "ctrl+d",
        "comments_list.resolve": "ctrl+r",
        "comments_list.delete": "ctrl+x",
        "comment_editor.submit": "ctrl+return, ctrl+enter, ctrl+j",
        "comment_editor.delete": "ctrl+x",
        "comment_editor.cancel": "escape",
        "error.retry": "r",
        "error.copy": "c",
        "error.quit": "ctrl+c, ctrl+d"
      }
    }
  },
  "additionalProperties": false
}

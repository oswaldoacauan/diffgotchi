    "diffContextBg": {
      "dark": "nightOwlPanel",
      "light": "nightOwlPanel"
    },
    "diffAddedLineNumberBg": {
      "dark": "#0a2e1a",
      "light": "#0a2e1a"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#2d1b1b",
      "light": "#2d1b1b"
    },
    "diffLineNumber": {
      "dark": "#7791a6",
      "light": "#7791a6"
    },
    "conceal": {
      "dark": "nightOwlMuted",
      "light": "nightOwlMuted"
    }

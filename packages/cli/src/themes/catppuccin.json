    "diffAddedLineNumberBg": {
      "dark": "#1e2a25",
      "light": "#c9e3cb"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#32232a",
      "light": "#e9d3d6"
    },
    "diffLineNumber": {
      "dark": "textMuted",
      "light": "#5b5d63"
    },
    "conceal": {
      "dark": "darkOverlay2",
      "light": "lightOverlay2"
    }

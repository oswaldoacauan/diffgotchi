  "theme": {
    "background": {
      "dark": "darkBase",
      "light": "lightBase"
    },
    "backgroundPanel": {
      "dark": "darkMantle",
      "light": "lightMantle"
    },
    "text": {
      "dark": "darkText",
      "light": "lightText"
    },
    "textMuted": {
      "dark": "darkOverlay2",
      "light": "lightOverlay2"
    },
    "primary": {
      "dark": "darkBlue",
      "light": "lightBlue"

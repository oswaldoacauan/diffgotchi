{
  "$schema": "https://diffgotchi.dev/schemas/theme.json",
  "defs": {
    "frappeRosewater": "#f2d5cf",
    "frappeFlamingo": "#eebebe",
    "frappePink": "#f4b8e4",
    "frappeMauve": "#ca9ee6",
    "frappeRed": "#e78284",
    "frappeMaroon": "#ea999c",
    "frappePeach": "#ef9f76",
    "frappeYellow": "#e5c890",
    "frappeGreen": "#a6d189",
    "frappeTeal": "#81c8be",

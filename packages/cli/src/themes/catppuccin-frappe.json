    "diffContextBg": {
      "dark": "frappeMantle",
      "light": "frappeMantle"
    },
    "diffAddedLineNumberBg": {
      "dark": "#223025",
      "light": "#223025"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#2f242b",
      "light": "#2f242b"
    },
    "diffLineNumber": "textMuted",
    "conceal": {
      "dark": "frappeOverlay2",
      "light": "frappeOverlay2"
